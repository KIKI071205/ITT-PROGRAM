class Solution:
    def swapPairs(self, head: Optional[ListNode]) -> Optional[ListNode]:
        dummy = ListNode(0, head)
        prev = dummy
        
        while prev.next and prev.next.next:
            # Nodes to be swapped
            first = prev.next
            second = prev.next.next
            
            # The actual swap
            prev.next = second
            first.next = second.next
            second.next = first
            
            # Re-position prev for the next pair
            prev = first
            
        return dummy.next
