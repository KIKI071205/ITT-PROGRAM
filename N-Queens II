class Solution:
    def totalNQueens(self, n: int) -> int:
        col = set()
        posDiag = set() # (r + c)
        negDiag = set() # (r - c)
        
        self.count = 0

        def backtrack(r):
            # Base case: Found a valid placement for all n queens
            if r == n:
                self.count += 1
                return

            for c in range(n):
                # If the square is under attack, skip it
                if c in col or (r + c) in posDiag or (r - c) in negDiag:
                    continue

                # Place queen and mark paths
                col.add(c)
                posDiag.add(r + c)
                negDiag.add(r - c)

                # Move to the next row
                backtrack(r + 1)

                # Backtrack: Remove queen and unmark paths
                col.remove(c)
                posDiag.remove(r + c)
                negDiag.remove(r - c)

        backtrack(0)
        return self.count
