class Solution:
    def isMatch(self, s: str, p: str) -> bool:
        s_ptr = p_ptr = 0
        star_idx = -1
        s_tmp_idx = -1
        
        while s_ptr < len(s):
            # 1. Characters match or pattern is '?'
            if p_ptr < len(p) and (p[p_ptr] == '?' or p[p_ptr] == s[s_ptr]):
                s_ptr += 1
                p_ptr += 1
            
            # 2. Pattern is '*'
            elif p_ptr < len(p) and p[p_ptr] == '*':
                # Record star position and the current string position to backtrack to
                star_idx = p_ptr
                s_tmp_idx = s_ptr
                p_ptr += 1
            
            # 3. Current characters don't match, but a previous '*' was found
            elif star_idx != -1:
                # Backtrack: the '*' matches one more character in 's'
                p_ptr = star_idx + 1
                s_tmp_idx += 1
                s_ptr = s_tmp_idx
            
            # 4. Characters don't match and no '*' to rescue us
            else:
                return False
        
        # Check if remaining characters in pattern are all '*'
        return all(x == '*' for x in p[p_ptr:])
