class Solution:
    def maxSubArray(self, nums: list[int]) -> int:
        max_sum = nums[0]
        current_sum = 0
        
        for n in nums:
            if current_sum < 0:
                current_sum = 0
            
            current_sum += n
            if current_sum > max_sum:
                max_sum = current_sum
                
        return max_sum
