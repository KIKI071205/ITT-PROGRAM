class Solution:
    def flatten(self, root: Optional[TreeNode]) -> None:
        """
        Do not return anything, modify root in-place instead.
        """
        curr = root
        
        while curr:
            if curr.left:
                
                last = curr.left
                while last.right:
                    last = last.right
                
                
                last.right = curr.right
                
                
                curr.right = curr.left
                curr.left = None
                
           
            curr = curr.right
