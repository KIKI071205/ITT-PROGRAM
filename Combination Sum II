class Solution:
    def combinationSum2(self, candidates: list[int], target: int) -> list[list[int]]:
        res = []
        candidates.sort()
        
        def backtrack(start, current_target, path):
            if current_target == 0:
                res.append(list(path))
                return
            
            for i in range(start, len(candidates)):
                # Optimization: stop if the number is already too large
                if candidates[i] > current_target:
                    break
                
                # Skip duplicates at the same recursion level
                if i > start and candidates[i] == candidates[i-1]:
                    continue
                
                path.append(candidates[i])
                # Move to i + 1 since each number is used only once
                backtrack(i + 1, current_target - candidates[i], path)
                path.pop()

        backtrack(0, target, [])
        return res
