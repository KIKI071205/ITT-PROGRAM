class Solution:
    def permuteUnique(self, nums: list[int]) -> list[list[int]]:
        res = []
        nums.sort()
        used = [False] * len(nums)
        
        def backtrack(path):
            if len(path) == len(nums):
                res.append(list(path))
                return
            
            for i in range(len(nums)):
                # Skip if already used in current path
                if used[i]:
                    continue
                
                # Skip duplicates: 
                # If current is same as previous AND previous hasn't been used 
                # in this branch, it means we already explored this value.
                if i > 0 and nums[i] == nums[i-1] and not used[i-1]:
                    continue
                
                used[i] = True
                path.append(nums[i])
                backtrack(path)
                
                # Backtrack
                path.pop()
                used[i] = False
                
        backtrack([])
        return res
