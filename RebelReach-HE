#include <stdio.h>
#include <stdlib.h>

#define MAXN 1000005
#define LOG 20

// Adjacency List Structure
typedef struct {
    int to;
    int next;
} Edge;

Edge edges[MAXN * 2];
int head[MAXN];
int edge_count;

// Binary Lifting and Prefix Sums
int up[MAXN][LOG];
long long S[MAXN];
int guards[MAXN];

// Iterative DFS Stack
int stack[MAXN];
int iter_ptr[MAXN]; // To track which edge we are currently processing for each node

void add_edge(int u, int v) {
    edges[edge_count].to = v;
    edges[edge_count].next = head[u];
    head[u] = edge_count++;
}

void iterative_dfs(int root, int n) {
    int top = 0;
    stack[top++] = root;
    
    // Initialize root
    S[root] = guards[root];
    for (int i = 0; i < LOG; i++) up[root][i] = root;
    for (int i = 1; i <= n; i++) iter_ptr[i] = head[i];

    while (top > 0) {
        int u = stack[top - 1];
        int found = 0;

        // Process edges of node u
        while (iter_ptr[u] != -1) {
            int v = edges[iter_ptr[u]].to;
            iter_ptr[u] = edges[iter_ptr[u]].next;

            if (v != up[u][0]) {
                up[v][0] = u;
                S[v] = S[u] + guards[v];
                
                // Build binary lifting table for v
                for (int i = 1; i < LOG; i++) {
                    up[v][i] = up[up[v][i - 1]][i - 1];
                }
                
                stack[top++] = v;
                found = 1;
                break; // Go deeper
            }
        }
        if (!found) top--; // Backtrack
    }
}

void solve() {
    int N;
    if (scanf("%d", &N) != 1) return;

    edge_count = 0;
    for (int i = 1; i <= N; i++) head[i] = -1;

    for (int i = 0; i < N - 1; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        add_edge(u, v);
        add_edge(v, u);
    }

    for (int i = 1; i <= N; i++) scanf("%d", &guards[i]);

    iterative_dfs(1, N);

    int Q;
    scanf("%d", &Q);
    while (Q--) {
        int U;
        long long X;
        scanf("%d %lld", &U, &X);

        // threshold: The point where rebels are completely stopped
        long long threshold = S[U] - X;

        // Check if they reach City 1
        if (S[1] > threshold) {
            printf("1\n");
        } else {
            int curr = U;
            // Jump upwards as long as the guards on the remaining path 
            // haven't stopped all rebels yet.
            for (int i = LOG - 1; i >= 0; i--) {
                if (S[up[curr][i]] > threshold) {
                    curr = up[curr][i];
                }
            }
            printf("%d\n", curr);
        }
    }
}

int main() {
    int T;
    if (scanf("%d", &T) != 1) return 0;
    while (T--) {
        solve();
    }
    return 0;
}
