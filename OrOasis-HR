#include <stdio.h>
#include <stdlib.h>

#define MAXN 1000005

int A[MAXN];
int prefix_or[MAXN];
int suffix_or[MAXN];
int bit_counts[32];

// Helper to add a number to the window bit counts
void add_to_window(int val, int *curr_or) {
    for (int i = 0; i < 31; i++) {
        if ((val >> i) & 1) {
            if (bit_counts[i] == 0) {
                *curr_or |= (1 << i);
            }
            bit_counts[i]++;
        }
    }
}

// Helper to remove a number from the window bit counts
void remove_from_window(int val, int *curr_or) {
    for (int i = 0; i < 31; i++) {
        if ((val >> i) & 1) {
            bit_counts[i]--;
            if (bit_counts[i] == 0) {
                *curr_or &= ~(1 << i);
            }
        }
    }
}

void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;

    int total_or = 0;
    for (int i = 0; i < n; i++) {
        scanf("%d", &A[i]);
        total_or |= A[i];
    }

    // Special case for all zeros
    if (total_or == 0) {
        printf("1 %d\n", n);
        return;
    }

    // Precompute prefix and suffix ORs
    int curr = 0;
    for (int i = 0; i < n; i++) {
        curr |= A[i];
        prefix_or[i] = curr;
    }
    curr = 0;
    for (int i = n - 1; i >= 0; i--) {
        curr |= A[i];
        suffix_or[i] = curr;
    }

    // Reset bit counts for sliding window
    for (int i = 0; i < 32; i++) bit_counts[i] = 0;

    int min_len = n + 1;
    long long count = 0;
    int right = 0;
    int curr_window_or = 0;

    for (int left = 0; left < n; left++) {
        // Expand right pointer until window OR matches total OR
        while (right < n && curr_window_or < total_or) {
            add_to_window(A[right], &curr_window_or);
            right++;
        }

        if (curr_window_or == total_or) {
            // Check Outer OR condition: (OR of 0..left-1) | (OR of right..n-1)
            int outer_or = 0;
            if (left > 0) outer_or |= prefix_or[left - 1];
            if (right < n) outer_or |= suffix_or[right];

            if (outer_or == total_or) {
                int current_len = right - left;
                if (current_len < min_len) {
                    min_len = current_len;
                    count = 1;
                } else if (current_len == min_len) {
                    count++;
                }
            }
        }
        
        // Move left pointer forward
        remove_from_window(A[left], &curr_window_or);
    }

    if (min_len > n) {
        printf("-1\n");
    } else {
        printf("%d %lld\n", min_len, count);
    }
}

int main() {
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    return 0;
}
