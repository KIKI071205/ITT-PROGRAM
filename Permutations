class Solution:
    def permute(self, nums: list[int]) -> list[list[int]]:
        res = []
        
        def backtrack(path):
            # Base case: current permutation is complete
            if len(path) == len(nums):
                res.append(list(path))
                return
            
            for num in nums:
                # If the number is already in the path, skip it
                if num in path:
                    continue
                
                path.append(num)
                backtrack(path)
                # Backtrack: remove the number to try a different one
                path.pop()

        backtrack([])
        return res
