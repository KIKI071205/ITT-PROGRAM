class Solution(object):
    def convert(self, s, numRows):
        # If there's only one row, or the string is too short to zigzag, return as is
        if numRows == 1 or numRows >= len(s):
            return s

        # Create a list of strings, one for each row
        rows = [""] * numRows
        current_row = 0
        going_down = False

        for char in s:
            rows[current_row] += char
            
            # If we are at the top or bottom row, we change direction
            if current_row == 0 or current_row == numRows - 1:
                going_down = not going_down
            
            # Move up or down based on our current direction
            if going_down:
                current_row += 1
            else:
                current_row -= 1

        # Join all row strings together for the final result
        return "".join(rows)
