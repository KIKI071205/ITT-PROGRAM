class Solution:
    def searchRange(self, nums, target):
        def find_bound(is_first):
            left, right = 0, len(nums) - 1
            bound = -1
            
            while left <= right:
                mid = (left + right) // 2
                
                if nums[mid] == target:
                    bound = mid
                    # If looking for first occurrence, search left half
                    if is_first:
                        right = mid - 1
                    # If looking for last occurrence, search right half
                    else:
                        left = mid + 1
                elif nums[mid] < target:
                    left = mid + 1
                else:
                    right = mid - 1
            return bound
        
        # Run binary search twice
        start = find_bound(is_first=True)
        end = find_bound(is_first=False)
        
        return [start, end]
